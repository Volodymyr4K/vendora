# BFF (Step 2)
PORT=4000
LOG_LEVEL=info

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/vendora?schema=public
INTERNAL_API_SECRET=please-set-a-long-random-secret-min-32-chars
WEB_BASE_URL=http://localhost:3000

# Cache
CACHE_MODE=memory
CACHE_TTL_SECONDS=60
CACHE_STALE_SECONDS=600
# REDIS_URL=redis://localhost:6379

# Media (R2 Proxy)
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=your-bucket-name
# R2_ACCESS_KEY_ID=your-access-key
# R2_SECRET_ACCESS_KEY=your-secret-key
# MEDIA_ROUTE_PREFIX=/media

# Upstream
UPSTREAM_MODE=mock
# UPSTREAM_BASE_URL=https://your-upstream.example
# UPSTREAM_HEADERS_JSON={"Authorization":"Bearer TOKEN"}
# UPSTREAM_ENDPOINTS_JSON={"branches":"/branches","branch":"/branches/{branch}","menu":"/menu","delivery":"/delivery/{branch}","quote":"/cart/quote","orderCreate":"/orders","orderStatus":"/orders/{orderId}"}

# Resilience
REQUEST_TIMEOUT_MS=4500
RETRY_COUNT=1
RETRY_BACKOFF_MS=250

# Rate limit
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Observability
METRICS_ENABLED=true
METRICS_ROUTE=/metrics
# SENTRY_DSN=

# Circuit breaker
BREAKER_ENABLED=true
BREAKER_FAILURE_THRESHOLD=5
BREAKER_OPEN_MS=20000
BREAKER_HALFOPEN_MAX=2

# Cache behavior
CACHE_SWR_ENABLED=true

# Checkout
IDEMPOTENCY_TTL_SECONDS=86400
ORDER_TTL_SECONDS=604800
ORDER_UPSTREAM_ENABLED=false

# Payments V2 (optional)
PAYMENTS_MODE=TEST                 # TEST|LIVE
PAYMENTS_INTERNAL_SYNC_ENABLED=false
# PAYMENTS_QUEUE_ENABLED=true
# PAYMENTS_WORKER_ENABLED=true
# PAYMENTS_WORKER_CONCURRENCY=5
# PAYMENTS_SWEEPER_ENABLED=true
# PAYMENTS_SWEEPER_INTERVAL_MS=60000
# PAYMENTS_SWEEPER_BATCH_SIZE=500

# Payments V2 — rehearsal tool (dev-only)
# PAYMENTS_REHEARSAL_ALLOW_REMOTE_DB=false
# PAYMENTS_REHEARSAL_WITH_REDIS=false

# Provider adapter mocks for rehearsal (dev-only; ignored in NODE_ENV=production)
# MOLLIE_API_BASE_URL=http://127.0.0.1:9999
# MONOBANK_API_BASE_URL=http://127.0.0.1:9999
# LIQPAY_API_BASE_URL=http://127.0.0.1:9999

# Upstream discovery helper
UPSTREAM_DISCOVERY_ENABLED=false
UPSTREAM_DISCOVERY_BRANCH_SLUG=armashivka
UPSTREAM_DISCOVERY_WRITE_FILE=true
UPSTREAM_DISCOVERY_SAVE_PATH=.cache/upstream_endpoints.json
UPSTREAM_DISCOVERY_TIMEOUT_MS=3500
# UPSTREAM_DISCOVERY_CANDIDATES_JSON={"branches":["/api/branches"],"menu":["/api/menu"],"delivery":["/api/delivery/{branch}"],"branch":["/api/branches/{branch}"],"quote":["/api/cart/quote"],"orderCreate":["/api/orders"],"orderStatus":["/api/orders/{orderId}"]}


# Step 9: Upstream normalization / adapters
UPSTREAM_ADAPTER=auto
UPSTREAM_UNWRAP_KEYS=data,result,payload,menu,response
UPSTREAM_RECORD_ENABLED=false
UPSTREAM_RECORD_DIR=.cache/upstream_raw
UPSTREAM_RECORD_MAX_BYTES=150000
DEBUG_ROUTES_ENABLED=false
