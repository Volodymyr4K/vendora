{
  "name": "@vendora/bff",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --experimental-specifier-resolution=node --import ./dist/instrumentation.js dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest run",
    "gates:payments": "pnpm typecheck && vitest run src/services/payments/__tests__ src/__tests__/integration/webhooks-raw-body.test.ts src/__tests__/integration/webhooks-liqpay-signature.test.ts src/__tests__/integration/webhooks-monobank-signature.test.ts src/__tests__/integration/webhooks-payments-skeleton.test.ts src/__tests__/integration/webhooks-payments-dedup.test.ts src/__tests__/integration/webhooks-payments-metrics.test.ts",
    "audit:payments:cleanup": "tsx src/tools/paymentsCleanupAudit.ts",
    "drill:payments": "tsx src/tools/paymentsIncidentDrillRunner.ts",
    "setup:payments:mollie-lab": "tsx src/tools/paymentsMollieLabSetup.ts",
    "probe": "tsx src/tools/probeUpstream.ts",
    "capture": "tsx src/tools/captureUpstream.ts",
    "smoke:upstream:http": "tsx src/tools/upstreamHttpSmoke.ts",
    "smoke:upstream:http:contract": "tsx src/tools/upstreamHttpContractSmoke.ts",
    "smoke:payments:rehearsal": "tsx src/tools/paymentsGoLiveRehearsal.ts",
    "typecheck": "tsc --noEmit",
    "check:tenant-prisma": "node scripts/check-tenant-prisma.mjs",
    "check:orderline-variant": "node scripts/check-orderline-variant.mjs"
  },
  "dependencies": {
    "@fastify/compress": "8.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "10.1.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "10.3.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.4",
    "@aws-sdk/client-s3": "^3.758.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.68.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.210.0",
    "@opentelemetry/resources": "^2.4.0",
    "@opentelemetry/sdk-node": "^0.210.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@vendora/contracts": "workspace:*",
    "@vendora/database": "workspace:*",
    "@vendora/shared": "workspace:*",
    "@vendora/tenant-resolver": "workspace:*",
    "@sentry/node": "8.54.0",
    "@slack/webhook": "^7.0.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.66.5",
    "dotenv": "16.4.7",
    "fastify": "5.6.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "5.6.1",
    "lru-cache": "^11.2.4",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "pino": "^10.1.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "15.1.3",
    "sharp": "^0.34.3",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/ioredis": "^5.0.0",
    "@types/node": "22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.5",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "@vitest/ui": "^4.0.16",
    "eslint": "^8.57.0",
    "tsx": "latest",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
