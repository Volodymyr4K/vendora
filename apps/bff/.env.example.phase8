# ============================================
# PHASE 8: Background Jobs & Monitoring
# ============================================

# Redis (for distributed locks in cron jobs)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Notifications (for domain verification failures)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Vendora Platform <noreply@vendora.com>"

# Slack Alerts (optional - for ops team notifications)
SLACK_WEBHOOK_URL=

# Cron Configuration
DOMAIN_VERIFICATION_INTERVAL=0 */6 * * *  # Every 6 hours (cron syntax)
GRACE_PERIOD_DAYS=7

# Metrics Security (reuse existing INTERNAL_API_SECRET)
# INTERNAL_API_SECRET=your-secret-key-here
