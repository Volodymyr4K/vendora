{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm --filter @vendora/web start",
      "startServerReadyPattern": "started server",
      "url": [
        "http://localhost:3000/choose-city",
        "http://localhost:3000/kyiv-bazhana/menu",
        "http://localhost:3000/kyiv-bazhana/menu/sets"
      ],
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.75
          }
        ],
        "largest-contentful-paint": [
          "warn",
          {
            "maxNumericValue": 3500
          }
        ],
        "cumulative-layout-shift": [
          "warn",
          {
            "maxNumericValue": 0.1
          }
        ],
        "total-blocking-time": [
          "warn",
          {
            "maxNumericValue": 500
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
