# Web (Next)
BFF_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3000

# BFF (Fastify)
UPSTREAM_BASE_URL=https://e-app.example/api
CACHE_MODE=memory
CACHE_TTL_SECONDS=60
CACHE_STALE_SECONDS=600
UPSTREAM_MODE=http
# Якщо ви не знаєте точні API-шляхи — увімкніть авто-discovery (Step 8):
UPSTREAM_DISCOVERY_ENABLED=true
UPSTREAM_DISCOVERY_BRANCH_SLUG=armashivka
UPSTREAM_DISCOVERY_WRITE_FILE=true
UPSTREAM_DISCOVERY_SAVE_PATH=.cache/upstream_endpoints.json
PORT=4000

# Required
DATABASE_URL=postgresql://user:password@localhost:5432/vendora?schema=public
INTERNAL_API_SECRET=please-set-a-long-random-secret-min-32-chars


# Step 9: Upstream normalization / adapters
UPSTREAM_ADAPTER=auto              # auto|passthrough|generic
UPSTREAM_UNWRAP_KEYS=data,result,payload,menu,response
UPSTREAM_RECORD_ENABLED=false
UPSTREAM_RECORD_DIR=.cache/upstream_raw
UPSTREAM_RECORD_MAX_BYTES=150000
DEBUG_ROUTES_ENABLED=false

# Payments V2 (optional)
PAYMENTS_MODE=TEST                 # TEST|LIVE
PAYMENTS_INTERNAL_SYNC_ENABLED=false
# PAYMENTS_QUEUE_ENABLED=true
# PAYMENTS_WORKER_ENABLED=true
# PAYMENTS_WORKER_CONCURRENCY=5
# PAYMENTS_SWEEPER_ENABLED=true
# PAYMENTS_SWEEPER_INTERVAL_MS=60000
# PAYMENTS_SWEEPER_BATCH_SIZE=500

# Payments V2 — rehearsal tool (dev-only)
# PAYMENTS_REHEARSAL_ALLOW_REMOTE_DB=false
# PAYMENTS_REHEARSAL_WITH_REDIS=false

# Provider adapter mocks for rehearsal (dev-only; ignored in NODE_ENV=production)
# MOLLIE_API_BASE_URL=http://127.0.0.1:9999
# MONOBANK_API_BASE_URL=http://127.0.0.1:9999
# LIQPAY_API_BASE_URL=http://127.0.0.1:9999
