{
    "annotations": {},
    "dashboard": {
        "id": null,
        "uid": "custom-domains",
        "title": "Custom Domains - Production Dashboard",
        "tags": [
            "domains",
            "production"
        ],
        "timezone": "browser",
        "schemaVersion": 38,
        "version": 0,
        "refresh": "30s"
    },
    "panels": [
        {
            "id": 1,
            "title": "Domain Status Overview",
            "type": "piechart",
            "targets": [
                {
                    "expr": "sum by (status) (domain_status_gauge)",
                    "legendFormat": "{{status}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {},
                    "mappings": [],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": null,
                                "color": "green"
                            }
                        ]
                    }
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 0
            }
        },
        {
            "id": 2,
            "title": "Verification Success Rate (24h)",
            "type": "gauge",
            "targets": [
                {
                    "expr": "rate(domain_verifications_total{status=\"success\"}[1h]) / rate(domain_verifications_total[1h]) * 100",
                    "legendFormat": "Success Rate",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": 0,
                                "color": "red"
                            },
                            {
                                "value": 70,
                                "color": "yellow"
                            },
                            {
                                "value": 90,
                                "color": "green"
                            }
                        ]
                    }
                }
            },
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 8,
                "y": 0
            }
        },
        {
            "id": 3,
            "title": "DNS Errors by Type",
            "type": "graph",
            "targets": [
                {
                    "expr": "sum by (error_type) (rate(domain_verifications_total{status=\"failure\"}[5m]))",
                    "legendFormat": "{{error_type}}",
                    "refId": "A"
                }
            ],
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 16,
                "y": 0
            }
        },
        {
            "id": 4,
            "title": "Domains in Grace Period",
            "type": "stat",
            "targets": [
                {
                    "expr": "count(domain_grace_period_started_at > 0)",
                    "legendFormat": "Grace Period",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": 0,
                                "color": "green"
                            },
                            {
                                "value": 10,
                                "color": "yellow"
                            },
                            {
                                "value": 50,
                                "color": "red"
                            }
                        ]
                    }
                }
            },
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 0,
                "y": 8
            }
        },
        {
            "id": 5,
            "title": "Cache Hit Rate",
            "type": "gauge",
            "targets": [
                {
                    "expr": "rate(cache_hits_total[5m]) / (rate(cache_hits_total[5m]) + rate(cache_misses_total[5m])) * 100",
                    "legendFormat": "Hit Rate",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "percent",
                    "min": 0,
                    "max": 100,
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": 0,
                                "color": "red"
                            },
                            {
                                "value": 70,
                                "color": "yellow"
                            },
                            {
                                "value": 85,
                                "color": "green"
                            }
                        ]
                    }
                }
            },
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 6,
                "y": 8
            }
        },
        {
            "id": 6,
            "title": "Active Domains",
            "type": "stat",
            "targets": [
                {
                    "expr": "active_domains_total",
                    "legendFormat": "Total",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "value": 0,
                                "color": "blue"
                            }
                        ]
                    }
                }
            },
            "gridPos": {
                "h": 4,
                "w": 6,
                "x": 12,
                "y": 8
            }
        },
        {
            "id": 7,
            "title": "Domain Resolution Latency (p95)",
            "type": "graph",
            "targets": [
                {
                    "expr": "histogram_quantile(0.95, rate(domain_resolution_duration_seconds_bucket[5m]))",
                    "legendFormat": "p95",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "unit": "s"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 12
            }
        },
        {
            "id": 8,
            "title": "Verification Attempts (5m rate)",
            "type": "graph",
            "targets": [
                {
                    "expr": "rate(domain_verifications_total[5m])",
                    "legendFormat": "Total",
                    "refId": "A"
                },
                {
                    "expr": "rate(domain_verifications_total{status=\"success\"}[5m])",
                    "legendFormat": "Success",
                    "refId": "B"
                },
                {
                    "expr": "rate(domain_verifications_total{status=\"failure\"}[5m])",
                    "legendFormat": "Failure",
                    "refId": "C"
                }
            ],
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 12
            }
        }
    ]
}